{
  "framework": "nextjs",
  "installCommand": "npm install && cd web && npm install",
  "buildCommand": "cd web && npm run build",
  "outputDirectory": "web/.next",
  "functions": {
    "web/api/roast.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/web/api/roast.py"
    }
  ]
}
